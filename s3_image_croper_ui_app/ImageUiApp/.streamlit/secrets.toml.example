# Streamlit native OIDC auth template (named-provider format).
#
# Copy to .streamlit/secrets.toml and fill in real values:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# DO NOT commit the real secrets.toml. It is gitignored at the repo root.
#
# On EC2, prefer storing the real file at /etc/imageuiapp/secrets.toml
# (root:ec2-user, mode 640) and symlinking from the working directory:
#   sudo install -d -o root -g ec2-user -m 750 /etc/imageuiapp
#   sudo install -o root -g ec2-user -m 640 /dev/null /etc/imageuiapp/secrets.toml
#   sudo nano /etc/imageuiapp/secrets.toml         # paste real values
#   ln -sf /etc/imageuiapp/secrets.toml \
#       <repo>/s3_image_croper_ui_app/ImageUiApp/.streamlit/secrets.toml
#
# Generate cookie_secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Streamlit 1.52 has a known issue with the single-provider [auth] block
# that causes "NoneType object does not support item assignment" at the
# OIDC callback. Use the named-provider form below instead. The app calls
# st.login("microsoft") to match.

[auth]
redirect_uri = "https://app.your-domain.example/oauth2callback"
cookie_secret = "REPLACE_WITH_RANDOM_32_BYTE_URLSAFE_STRING"

[auth.microsoft]
client_id = "REPLACE_WITH_ENTRA_APPLICATION_CLIENT_ID"
client_secret = "REPLACE_WITH_ENTRA_CLIENT_SECRET"
server_metadata_url = "https://login.microsoftonline.com/REPLACE_WITH_TENANT_ID/v2.0/.well-known/openid-configuration"
client_kwargs = { scope = "openid profile email", prompt = "select_account" }
