# Default: treat text as text and normalize internally
* text=auto

# Always use LF for all text files (Pi target + WSL2 consistency)
*.sh      text eol=lf
*.bash    text eol=lf
*.py      text eol=lf
*.service text eol=lf
*.timer   text eol=lf
*.toml    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.txt     text eol=lf
*.cfg     text eol=lf
*.ini     text eol=lf

# Optional: explicit for common project files
Dockerfile text eol=lf
Makefile   text eol=lf
