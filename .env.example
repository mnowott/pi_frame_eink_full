# AWS credentials for all modules
# Copy this file to .env and fill in real values:
#   cp .env.example .env

AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=eu-central-1
S3_BUCKET=your-bucket-name

# Required only on the EC2 host running ImageUiApp behind Caddy
# (install_as_aws_linux_caddy.sh). Not used on Pi.
APP_DOMAIN=app.your-domain.example
ADMIN_EMAIL=you@your-domain.example

# IaC / admin-role assume (scripts/aws/assume_admin.sh).
# Set after deploying infrastructure/cloudformation/admin-role/.
AWS_ADMIN_ROLE_ARN=arn:aws:iam::REPLACE_WITH_ACCOUNT_ID:role/imageuiapp-admin

# Pick ONE of the two below:
#   SSO path (preferred). Name of the AWS CLI profile configured for SSO:
# AWS_SSO_PROFILE=my-sso-profile
#   MFA path. ARN of your virtual MFA device:
# AWS_MFA_SERIAL=arn:aws:iam::REPLACE_WITH_ACCOUNT_ID:mfa/your-device-name
